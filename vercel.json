{
  "cleanUrls": true,

  "headers": [
    {
      "source": "/apple-touch-icon.png",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/manifest.json",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400" }]
    },
    {
      "source": "/sitemap.xml",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400" }]
    },
    {
      "source": "/robots.txt",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400" }]
    }
  ],

  "redirects": [
    { "source": "/cursos",        "destination": "https://ruiveran.gumroad.com/", "permanent": false },
    { "source": "/tienda",        "destination": "https://www.inprnt.com/",        "permanent": false },
    { "source": "/store",         "destination": "https://www.inprnt.com/",        "permanent": false },
    { "source": "/courses",       "destination": "https://ruiveran.gumroad.com/", "permanent": false },
    { "source": "/clases/",       "destination": "/clases",                        "permanent": true  },
    { "source": "/contact/",      "destination": "/contact",                       "permanent": true  },
    { "source": "/inicio",        "destination": "/",                              "permanent": true  },
    { "source": "/home",          "destination": "/",                              "permanent": true  }
  ]
}
